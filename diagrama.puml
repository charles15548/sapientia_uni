@startuml
title Sapientia UNI Backend - Organizacion completa del proyecto
top to bottom direction

skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam ArrowColor #2F5D8C
skinparam packageBorderColor #5B7C99
skinparam packageBackgroundColor #F7FAFC
skinparam rectangleBorderColor #5B7C99
skinparam rectangleBackgroundColor #FFFFFF
skinparam databaseBorderColor #8A6D3B
skinparam databaseBackgroundColor #FFF8E8
skinparam folderBorderColor #6B8E23
skinparam folderBackgroundColor #F6FFF0
skinparam cloudBorderColor #4A6FA5
skinparam cloudBackgroundColor #EEF5FF

actor "Cliente / Frontend" as CLIENTE
rectangle "FastAPI\napp.py" as API

folder "Proyecto back/" as ROOT {
  artifact ".env" as ENV
  artifact "requirements.txt" as REQ
  artifact "test.py\n(sin contenido)" as TEST

  folder "out/" as OUT {
    folder "diagrama/" as OUT_DIAG {
      artifact "diagrama.png" as DIAG_PNG
    }
  }

  folder "script/" as SCRIPT {
    folder "bd/" as PKG_BD {
      artifact "db.py" as DB_PY
      artifact "delete-db.py" as DELETE_DB_PY
    }

    folder "controllers/" as PKG_CTRL {
      artifact "personas.py" as CTRL_PERSONAS
      artifact "libro.py" as CTRL_LIBRO
      artifact "capitulos.py" as CTRL_CAPITULOS
    }

    folder "service/" as PKG_SRV {
      artifact "libroCapitulosService.py" as SRV_LIBCAP
    }

    folder "llm/" as PKG_LLM {
      artifact "variables_globales.py" as LLM_VARS
      artifact "response.py" as LLM_RESPONSE

      folder "gpt/" as PKG_GPT {
        artifact "prompt.py" as GPT_PROMPT
        artifact "construccion_mensajeLLM.py" as GPT_MSG
      }

      folder "embeddings/" as PKG_EMB {
        artifact "embedding.py" as EMB_CORE
        artifact "select_chunks.py" as EMB_SELECT

        folder "libros/" as PKG_LIBROS {
          artifact "subir_libro.py" as LIB_SUBIR
          artifact "subir_capitulos.py" as LIB_CAPITULOS
          artifact "extraer_paginas.py" as LIB_PAGINAS
          artifact "formatear_libro.py" as LIB_FORMATO
        }
      }
    }
  }

  folder ".venv/" as VENV
  folder "__pycache__/" as CACHE
}

database "PostgreSQL + pgvector\npersona, libros, capitulos,\nsubcapitulos, document_chunks" as DB
folder "Storage en disco\n/data/libros" as DISK
cloud "OpenAI API\nchat.completions + embeddings" as OPENAI

CLIENTE --> API

API --> CTRL_PERSONAS : POST /acceso
API --> CTRL_LIBRO : GET /libros\nGET /libros/{id}/descargar\nDELETE /libros/{id_libro}
API --> CTRL_CAPITULOS : GET /libros/con-capitulos\nCRUD capitulos/subcapitulos
API --> LLM_RESPONSE : POST /consultar-stream
API --> LIB_SUBIR : POST /subir-libro\nPOST /disk/subir-manual

CTRL_PERSONAS --> DB_PY
CTRL_LIBRO --> DB_PY
CTRL_CAPITULOS --> DB_PY
DELETE_DB_PY --> DB
DB_PY --> DB

LLM_RESPONSE --> EMB_SELECT
LLM_RESPONSE --> GPT_MSG
LLM_RESPONSE --> LLM_VARS
LLM_RESPONSE --> OPENAI

GPT_MSG --> GPT_PROMPT
GPT_MSG --> CTRL_CAPITULOS : obtener_listado_libros_con_capitulos()
GPT_MSG --> SRV_LIBCAP : formatear_listado_libros()

EMB_SELECT --> EMB_CORE
EMB_SELECT --> GPT_PROMPT
EMB_SELECT --> LLM_VARS
EMB_SELECT --> DB : busqueda vectorial
EMB_SELECT --> OPENAI : reformular pregunta

LIB_SUBIR --> LIB_PAGINAS
LIB_SUBIR --> LIB_FORMATO
LIB_SUBIR --> LIB_CAPITULOS
LIB_SUBIR --> CTRL_LIBRO : subirLibro()
LIB_SUBIR --> LLM_VARS
LIB_SUBIR --> DISK

LIB_CAPITULOS --> GPT_PROMPT
LIB_CAPITULOS --> LLM_VARS
LIB_CAPITULOS --> SRV_LIBCAP : limpiar_titulo()
LIB_CAPITULOS --> OPENAI

LIB_PAGINAS --> LIB_FORMATO
LIB_PAGINAS --> LLM_VARS

CTRL_LIBRO --> EMB_CORE : dividir_en_chunks()\nlimpiar_texto()\ngenerar_embedding()
CTRL_LIBRO --> DISK : FileResponse descarga

EMB_CORE --> LLM_VARS
EMB_CORE --> OPENAI : text-embedding-3-small

DB_PY ..> ENV : DATABASE_URL
LLM_RESPONSE ..> ENV : OPENAI_API_KEY
EMB_CORE ..> ENV : OPENAI_API_KEY
EMB_SELECT ..> ENV : OPENAI_API_KEY + DATABASE_URL
LIB_CAPITULOS ..> ENV : OPENAI_API_KEY
LIB_SUBIR ..> ENV : OPENAI_API_KEY

REQ ..> API : dependencias runtime
REQ ..> SCRIPT
VENV ..> REQ : entorno local
CACHE ..> SCRIPT : archivos compilados
TEST ..> API : placeholder para pruebas manuales
OUT_DIAG ..> DIAG_PNG : artefacto renderizado

note right of LIB_SUBIR
  Orquesta toda la ingesta:
  guardar archivo, extraer texto,
  detectar capitulos con LLM,
  limpiar texto RAG e indexar chunks.
end note

note left of LLM_RESPONSE
  Flujo RAG en streaming:
  1) reformulacion conversacional
  2) seleccion vectorial de chunks
  3) construccion de prompt
  4) respuesta SSE al cliente
end note

@enduml
